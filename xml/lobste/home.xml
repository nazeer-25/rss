ckColumn&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTA2MiIgaGVpZ2h0PSI1MDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyIgdmVyc2lvbj0iMS4xIi8+&#34;&gt;&lt;/div&gt;&#xA;&lt;img src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;div class=&#34;stackRow&#34;&gt;&#xA;&lt;div class=&#34;Home_singleCol__21m79&#34;&gt;&lt;div class=&#34;stackColumn&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTMwNiIgaGVpZ2h0PSI3MTgiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyIgdmVyc2lvbj0iMS4xIi8+&#34;&gt;&lt;/div&gt;&#xA;&lt;img src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;div class=&#34;Home_singleCol__21m79&#34;&gt;&lt;div class=&#34;stackColumn&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iODExIiBoZWlnaHQ9IjUxMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIiB2ZXJzaW9uPSIxLjEiLz4=&#34;&gt;&lt;/div&gt;&#xA;&lt;img src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&lt;div class=&#34;stackRow&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTMyNCIgaGVpZ2h0PSIxMjI0IiB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZlcnNpb249IjEuMSIvPg==&#34;&gt;&lt;/div&gt;&#xA;&lt;img alt=&#34;showcase of file structure&#34; src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&lt;div class=&#34;stackRow&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAwIiBoZWlnaHQ9IjYwMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIiB2ZXJzaW9uPSIxLjEiLz4=&#34;&gt;&lt;/div&gt;&#xA