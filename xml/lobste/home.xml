      <description>&lt;div&gt;Article:&lt;div&gt;&lt;br/&gt;&lt;br/&gt;&lt;div&gt;&lt;main class=&#34;Home_main__1x8gC&#34;&gt;&lt;div&gt;&#xA;&lt;div class=&#34;stackRow&#34;&gt;&lt;div class=&#34;embla-max-width&#34;&gt;&lt;div class=&#34;embla__viewport&#34;&gt;&lt;div class=&#34;embla__container&#34;&gt;&#xA;&lt;div class=&#34;embla__slide&#34;&gt;&lt;div class=&#34;embla__slide__inner&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iOTAwIiBoZWlnaHQ9IjU1MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIiB2ZXJzaW9uPSIxLjEiLz4=&#34;&gt;&lt;/div&gt;&#xA;&lt;img alt=&#34;local renaming showcase&#34; src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34; class=&#34;embla__slide__img&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;div class=&#34;embla__slide&#34;&gt;&lt;div class=&#34;embla__slide__inner&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTAwMCIgaGVpZ2h0PSI2MDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyIgdmVyc2lvbj0iMS4xIi8+&#34;&gt;&lt;/div&gt;&#xA;&lt;img alt=&#34;struct renaming showcase&#34; src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34; class=&#34;embla__slide__img&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;div class=&#34;stackRow&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iOTAwIiBoZWlnaHQ9IjU1MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIiB2ZXJzaW9uPSIxLjEiLz4=&#34;&gt;&lt;/div&gt;&#xA;&lt;img alt=&#34;quick refactoring showcase&#34; src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34; class=&#34;embla__slide__img&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;div class=&#34;stackRow&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNzc0IiBoZWlnaHQ9IjM1MyIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIiB2ZXJzaW9uPSIxLjEiLz4=&#34;&gt;&lt;/div&gt;&#xA;&lt;img alt=&#34;auto completion showcase&#34; src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&lt;div&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTU4NyIgaGVpZ2h0PSI4NzYiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyIgdmVyc2lvbj0iMS4xIi8+&#34;&gt;&lt;/div&gt;&#xA;&lt;img alt=&#34;Documentation Explorer&#34; src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;div&gt;&#xA;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjI1OCIgaGVpZ2h0PSIxNDQwIiB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZlcnNpb249IjEuMSIvPg==&#34;&gt;&lt;/div&gt;&#xA;&lt;img alt=&#34;Documentation Explorer&#34; src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34;&gt;&#xA;&lt;/div&gt;&#xA;&lt;div&gt;&lt;div class=&#34;stackColumn&#34;&gt;&#xA;&lt;p class=&#34;stackRow&#34;&gt;&lt;button class=&#34;Stack_tabButton__2Ai4o&#34;&gt;regex search in a directory&lt;/button&gt;&lt;button class=&#34;Stack_tabButton__2Ai4o&#34;&gt;Search files in a specifig language&lt;/button&gt;&lt;/p&gt;&#xA;&lt;div&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTEzNiIgaGVpZ2h0PSI3NjYiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyIgdmVyc2lvbj0iMS4xIi8+&#34;&gt;&lt;/div&gt;&#xA;&lt;img alt=&#34;showcase of searching for a struct&#39;s implementations&#34; src=&#34;data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7&#34;&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;div&gt;&#xA;&lt;div class=&#34;stackRow&#34;&gt;&lt;div&gt;&#xA;&lt;div&gt;&lt;img alt src=&#34;data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iODQyIiBoZWlnaHQ9I